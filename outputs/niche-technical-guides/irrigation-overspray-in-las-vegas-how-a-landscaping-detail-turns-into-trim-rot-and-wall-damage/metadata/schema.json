      {
        "@type": "Question",
        "name": "Why is this common in a desert city?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Because irrigation is frequent enough to create repeated wetting even where rainfall is low. LVVWD also actively regulates watering schedules and water-waste practices."
        }
